<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Koniec_gry">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Koniec Gry"
        android:textAllCaps="true"
        android:textSize="30sp"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="75dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/najlepszyWynik"
         />

    <TextView
        android:id="@+id/najlepszyWynik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:text="Najlepszy wynik: "
        android:textAllCaps="true"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/wynikGry"
        />

    <TextView
        android:id="@+id/wynikGry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textSize="17sp"
        android:text="Twój wynik: "
        android:textAllCaps="true"
        app:layout_constraintTop_toBottomOf="@id/najlepszyWynik"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nickGracza"
         />


    <AutoCompleteTextView
        android:id="@+id/nickGracza"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:hint="Podaj nick do zapisania wyniku:"
        app:layout_constraintTop_toBottomOf="@id/wynikGry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
         />

    <ImageButton
        android:id="@+id/przejdzDoRankingu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ranking"
        android:background="#00000000"
        app:layout_constraintTop_toBottomOf="@id/nickGracza"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/zagrajPonownie"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageButton
        android:id="@+id/zagrajPonownie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/zagraj_ponownie"
        android:background="#00000000"
        app:layout_constraintTop_toBottomOf="@id/nickGracza"
        app:layout_constraintStart_toEndOf="@id/przejdzDoRankingu"
        app:layout_constraintEnd_toStartOf="@id/przejdzDoStronyGlownej"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <ImageButton
        android:id="@+id/przejdzDoStronyGlownej"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/strona_glowna"
        android:background="#00000000"
        app:layout_constraintTop_toBottomOf="@id/nickGracza"
        app:layout_constraintStart_toEndOf="@id/zagrajPonownie"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>